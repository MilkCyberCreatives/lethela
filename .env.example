# Core
NODE_ENV=development
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Auth (NextAuth)
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-long-random-string
VENDOR_SESSION_SECRET=
RIDER_CONSOLE_SECRET=
ADMIN_APPROVAL_KEY=

# Database
# Local development uses SQLite. Production must use PostgreSQL.
DATABASE_PROVIDER=sqlite
DATABASE_URL=file:./dev.db

# Catalog mode
DEMO_CATALOG_MODE=false

# AI
OPENAI_API_KEY=

# Maps
GOOGLE_MAPS_API_KEY=

# Realtime
PUSHER_APP_ID=
PUSHER_KEY=
PUSHER_SECRET=
PUSHER_CLUSTER=
NEXT_PUBLIC_PUSHER_KEY=
NEXT_PUBLIC_PUSHER_CLUSTER=

# Web Push
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
WEB_PUSH_VAPID_PRIVATE_KEY=
WEB_PUSH_SUBJECT=mailto:support@lethela.com

# Payments (ZA)
OZOW_SITE_CODE=
OZOW_PRIVATE_KEY=
# Set to false for live payments.
OZOW_IS_TEST=true
NEXT_PUBLIC_OZOW_IS_TEST=true

# Storage
# Required for durable uploads in production.
STORAGE_BUCKET_URL=
SUPABASE_URL=
SUPABASE_SERVICE_ROLE=
SUPABASE_BUCKET=

# Observability
SENTRY_DSN=
SENTRY_ENVIRONMENT=

# SEO + Search Console Verification
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=
NEXT_PUBLIC_BING_SITE_VERIFICATION=
NEXT_PUBLIC_FACEBOOK_DOMAIN_VERIFICATION=

# Marketing tags (set only what you use)
NEXT_PUBLIC_GA4_ID=
NEXT_PUBLIC_GTM_ID=
NEXT_PUBLIC_META_PIXEL_ID=

# WhatsApp ordering
NEXT_PUBLIC_WHATSAPP_ORDER_PHONE=27723908919

# Admin notifications
ADMIN_NOTIFICATION_EMAILS=
ADMIN_NOTIFICATION_EMAIL_FROM=
ADMIN_NOTIFICATION_WHATSAPP_TO=
RESEND_API_KEY=
PASSWORD_RESET_EMAIL_FROM=
PASSWORD_RESET_SECRET=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=
