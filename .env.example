# Core
NODE_ENV=development
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Auth (NextAuth)
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-long-random-string
VENDOR_SESSION_SECRET=
RIDER_CONSOLE_SECRET=
ADMIN_APPROVAL_KEY=
# Local development only. Keep false in production.
ALLOW_DEV_ADMIN_BYPASS=false

# Database
# Local development uses SQLite. Production must use PostgreSQL.
DATABASE_PROVIDER=sqlite
DATABASE_URL=file:./dev.db

# Catalog mode
DEMO_CATALOG_MODE=false
ALLOW_PUBLIC_DEMO_ORDER=false

# Operating gates
MIN_PILOT_VENDORS=1
MIN_PILOT_PRODUCTS=5
MIN_PILOT_RIDERS=1
MIN_PILOT_PAID_ORDERS=1
MIN_PUBLIC_VENDORS=3
MIN_PUBLIC_PRODUCTS=20
MIN_PUBLIC_RIDERS=2
MIN_PUBLIC_PAID_ORDERS=5

# AI
OPENAI_API_KEY=

# Maps
GOOGLE_MAPS_API_KEY=
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# Realtime
PUSHER_APP_ID=
PUSHER_KEY=
PUSHER_SECRET=
PUSHER_CLUSTER=
NEXT_PUBLIC_PUSHER_KEY=
NEXT_PUBLIC_PUSHER_CLUSTER=

# Web Push
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
WEB_PUSH_VAPID_PRIVATE_KEY=
WEB_PUSH_SUBJECT=mailto:support@lethela.com

# Payments (ZA)
OZOW_SITE_CODE=
OZOW_PRIVATE_KEY=
# Set to false for live payments.
OZOW_IS_TEST=true
NEXT_PUBLIC_OZOW_IS_TEST=true

# Storage
# Required for durable uploads in production.
UPLOAD_STORAGE=local
STORAGE_LOCAL_DIR=
STORAGE_PUBLIC_PATH=/uploads
STORAGE_BUCKET_URL=
SUPABASE_URL=
SUPABASE_SERVICE_ROLE=
SUPABASE_BUCKET=
# Use a separate private bucket with public access disabled for identity, banking and licence files.
SUPABASE_PRIVATE_BUCKET=
# Optional local-only private file root. Defaults to .data/private-uploads.
STORAGE_PRIVATE_DIR=

# Commercial calculation (basis points; 1000 = 10%).
PLATFORM_COMMISSION_BPS=1000

# Observability
SENTRY_DSN=
SENTRY_ENVIRONMENT=

# SEO + Search Console Verification
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=
NEXT_PUBLIC_BING_SITE_VERIFICATION=
NEXT_PUBLIC_FACEBOOK_DOMAIN_VERIFICATION=

# Marketing tags (set only what you use)
NEXT_PUBLIC_GA4_ID=
NEXT_PUBLIC_GTM_ID=
NEXT_PUBLIC_META_PIXEL_ID=

# WhatsApp ordering
NEXT_PUBLIC_WHATSAPP_ORDER_PHONE=27723908919

# Admin notifications
ADMIN_NOTIFICATION_EMAILS=
ADMIN_NOTIFICATION_EMAIL_FROM=
ADMIN_NOTIFICATION_WHATSAPP_TO=
RESEND_API_KEY=
PASSWORD_RESET_EMAIL_FROM=
PASSWORD_RESET_SECRET=
NEXT_PUBLIC_SUPPORT_EMAIL=support@lethela.co.za
NEXT_PUBLIC_LEGAL_ENTITY_NAME=Lethela
NEXT_PUBLIC_INFO_OFFICER_NAME=Lethela Support Team
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=
