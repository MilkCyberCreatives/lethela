datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id                  String    @id @default(cuid())
  email               String    @unique
  name                String?
  phone               String?
  image               String?
  passwordHash        String?
  role                String    @default("CUSTOMER")
  emailVerifiedAt     DateTime?
  failedLoginAttempts Int       @default(0)
  lockedUntil         DateTime?
  sessionVersion      Int       @default(0)
  twoFactorEnabled    Boolean   @default(false)
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  memberships      VendorMember[]
  orders           Order[]               @relation("CustomerOrders")
  ownedVendors     Vendor[]              @relation("VendorOwner")
  favoriteProducts UserFavoriteProduct[]
  productReviews   UserProductReview[]
  pushPreferences  PushPreference[]
  pushCampaigns    PushCampaign[]        @relation("PushCampaignCreator")
  riderApplication RiderApplication?
  privacyRequests  PrivacyRequest[]
}

model PrivacyRequest {
  id        String   @id @default(cuid())
  userId    String
  type      String
  status    String   @default("OPEN")
  details   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Restrict)

  @@index([userId, createdAt])
  @@index([status, createdAt])
}

model Visitor {
  id            String   @id
  preferredArea String?
  userAgent     String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  events            VisitorEvent[]
  pushSubscriptions PushSubscription[]
  pushPreferences   PushPreference[]

  @@index([preferredArea])
  @@index([updatedAt])
}

model VisitorEvent {
  id          String   @id @default(cuid())
  visitorId   String
  userId      String?
  type        String
  path        String?
  vendorId    String?
  vendorSlug  String?
  productId   String?
  searchQuery String?
  metaJson    String?
  createdAt   DateTime @default(now())

  visitor Visitor @relation(fields: [visitorId], references: [id], onDelete: Cascade)

  @@index([visitorId, createdAt])
  @@index([type, createdAt])
  @@index([vendorSlug])
}

model PushSubscription {
  id        String   @id @default(cuid())
  visitorId String
  userId    String?
  endpoint  String   @unique
  p256dh    String
  auth      String
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  visitor Visitor @relation(fields: [visitorId], references: [id], onDelete: Cascade)

  @@index([visitorId, updatedAt])
}

model PushPreference {
  id                     String   @id @default(cuid())
  visitorId              String   @unique
  userId                 String?
  marketingEnabled       Boolean  @default(true)
  orderUpdatesEnabled    Boolean  @default(true)
  recommendationsEnabled Boolean  @default(true)
  adminAlertsEnabled     Boolean  @default(true)
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  visitor Visitor @relation(fields: [visitorId], references: [id], onDelete: Cascade)
  user    User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId, updatedAt])
}

model Vendor {
  id                       String    @id @default(cuid())
  name                     String
  slug                     String    @unique
  email                    String?   @unique
  phone                    String?
  address                  String?
  suburb                   String?
  city                     String?
  province                 String?
  municipality             String?
  township                 String?
  sectionArea              String?
  storeType                String?
  latitude                 Float?
  longitude                Float?
  isActive                 Boolean   @default(false)
  status                   String    @default("DRAFT")
  ownerId                  String?
  description              String?
  coverImage               String?
  pickupInstructions       String?
  temporaryClosed          Boolean   @default(false)
  preparationMinutes       Int       @default(30)
  orderCapacity            Int       @default(20)
  reviewReason             String?
  submittedAt              DateTime?
  kycIdUrl                 String?
  kycProofUrl              String?
  bankName                 String?
  bankAccountName          String?
  bankAccountNumber        String?
  bankBranchCode           String?
  bankAccountType          String?
  bankVerificationStatus   String    @default("UNVERIFIED")
  liquorLicenceUrl         String?
  liquorLicenceNumber      String?
  liquorLicenceHolder      String?
  liquorLicencePremises    String?
  liquorLicenceProvince    String?
  liquorLicenceType        String?
  liquorLicenceExpiry      DateTime?
  liquorVerificationStatus String    @default("NOT_APPLICABLE")
  liquorReviewReason       String?
  cuisine                  String    @default("[]")
  rating                   Float     @default(4.4)
  deliveryFee              Int       @default(1500)
  etaMins                  Int       @default(30)
  halaal                   Boolean   @default(false)
  image                    String?

  owner     User?               @relation("VendorOwner", fields: [ownerId], references: [id], onDelete: SetNull)
  products  Product[]
  orders    Order[]
  hours     OperatingHour[]
  specials  Special[]
  members   VendorMember[]
  sections  MenuSection[]
  items     Item[]
  upsells   ProductUpsell[]
  lateFlags LateOrderFlag[]
  reviews   UserProductReview[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive, updatedAt])
  @@index([name])
  @@index([isActive, status, updatedAt])
  @@index([suburb])
}

model VendorMember {
  id        String   @id @default(cuid())
  vendorId  String
  userId    String
  role      String   @default("OWNER")
  createdAt DateTime @default(now())

  vendor Vendor @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([vendorId, userId])
}

model Product {
  id           String   @id @default(cuid())
  vendorId     String
  name         String
  slug         String
  description  String?
  priceCents   Int
  image        String?
  isAlcohol    Boolean  @default(false)
  status       String   @default("SUBMITTED")
  reviewReason String?
  abv          Float?
  inStock      Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  vendor     Vendor                @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  specials   Special[]
  orderItems OrderItem[]
  baseFor    ProductUpsell[]       @relation("BaseProduct")
  upsellFor  ProductUpsell[]       @relation("UpsellProduct")
  favorites  UserFavoriteProduct[]
  reviews    UserProductReview[]

  @@unique([vendorId, slug])
  @@index([vendorId, updatedAt])
  @@index([status, updatedAt])
  @@index([name])
}

model UserFavoriteProduct {
  id        String   @id @default(cuid())
  userId    String
  productId String
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
  @@index([userId, createdAt])
  @@index([productId])
}

model UserProductReview {
  id        String   @id @default(cuid())
  userId    String
  productId String
  vendorId  String
  rating    Int
  comment   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  vendor  Vendor  @relation(fields: [vendorId], references: [id], onDelete: Cascade)

  @@unique([userId, productId])
  @@index([vendorId, createdAt])
  @@index([productId, createdAt])
}

model MenuSection {
  id        String   @id @default(cuid())
  vendorId  String
  title     String
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  vendor Vendor @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  items  Item[]

  @@unique([vendorId, title])
  @@index([vendorId, sortOrder])
}

model Item {
  id          String   @id @default(cuid())
  vendorId    String
  sectionId   String
  name        String
  description String?
  priceCents  Int
  tags        String   @default("[]")
  image       String?
  isAlcohol   Boolean  @default(false)
  draft       Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  vendor  Vendor      @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  section MenuSection @relation(fields: [sectionId], references: [id], onDelete: Cascade)

  @@index([vendorId, sectionId])
}

model OperatingHour {
  id       String  @id @default(cuid())
  vendorId String
  day      Int
  openMin  Int
  closeMin Int
  closed   Boolean @default(false)

  vendor Vendor @relation(fields: [vendorId], references: [id], onDelete: Cascade)

  @@unique([vendorId, day])
  @@index([vendorId])
}

model Order {
  id                    String    @id @default(cuid())
  publicId              String    @unique @default(cuid())
  vendorId              String
  userId                String?
  status                String    @default("PENDING_PAYMENT")
  statusReason          String?
  liquorIdVerifiedAt    DateTime?
  paymentStatus         String    @default("PENDING")
  ozowReference         String?   @unique
  ozowTxnId             String?   @unique
  checkoutKey           String?   @unique
  paymentCallbackAt     DateTime?
  assignedRiderId       String?
  customerLat           Float?
  customerLng           Float?
  riderLat              Float?
  riderLng              Float?
  riderSpeed            Float?
  riderLocatedAt        DateTime?
  distanceKm            Float?
  subtotalCents         Int       @default(0)
  deliveryFeeCents      Int       @default(0)
  riderTipCents         Int       @default(0)
  riderPayoutCents      Int       @default(0)
  vendorPayoutCents     Int       @default(0)
  platformFeeCents      Int       @default(0)
  riderPayoutStatus     String    @default("PENDING")
  riderPayoutReference  String?
  riderPayoutDate       DateTime?
  vendorPayoutStatus    String    @default("PENDING")
  vendorPayoutReference String?
  vendorPayoutDate      DateTime?
  totalCents            Int       @default(0)
  amountCents           Int       @default(0)
  itemsJson             String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  vendor        Vendor            @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  user          User?             @relation("CustomerOrders", fields: [userId], references: [id], onDelete: SetNull)
  assignedRider RiderApplication? @relation(fields: [assignedRiderId], references: [id], onDelete: SetNull)
  items         OrderItem[]
  lateFlags     LateOrderFlag[]

  @@index([vendorId, createdAt])
  @@index([status, createdAt])
  @@index([assignedRiderId, status, createdAt])
}

model OrderItem {
  id         String  @id @default(cuid())
  orderId    String
  productId  String?
  qty        Int
  priceCents Int

  order   Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product? @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@index([orderId])
  @@index([productId])
}

model Special {
  id          String   @id @default(cuid())
  vendorId    String
  productId   String?
  title       String
  description String?
  discountPct Int
  startsAt    DateTime
  endsAt      DateTime
  draft       Boolean  @default(false)

  vendor  Vendor   @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  product Product? @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@index([vendorId, startsAt])
  @@index([endsAt])
}

model ProductUpsell {
  id              String  @id @default(cuid())
  vendorId        String
  baseProductId   String
  upsellProductId String
  blurb           String?

  vendor        Vendor  @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  baseProduct   Product @relation("BaseProduct", fields: [baseProductId], references: [id], onDelete: Cascade)
  upsellProduct Product @relation("UpsellProduct", fields: [upsellProductId], references: [id], onDelete: Cascade)

  @@unique([vendorId, baseProductId, upsellProductId])
  @@index([vendorId])
}

model LateOrderFlag {
  id          String   @id @default(cuid())
  vendorId    String
  orderId     String
  orderPublic String   @unique
  etaMinutes  Int
  createdAt   DateTime @default(now())
  resolved    Boolean  @default(false)
  aiMessage   String?

  vendor Vendor @relation(fields: [vendorId], references: [id], onDelete: Cascade)
  order  Order  @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([vendorId, createdAt])
  @@index([orderId])
}

model PushCampaign {
  id              String   @id @default(cuid())
  title           String
  body            String
  url             String   @default("/")
  segment         String   @default("ALL")
  sentCount       Int      @default(0)
  failedCount     Int      @default(0)
  createdByUserId String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  createdBy User? @relation("PushCampaignCreator", fields: [createdByUserId], references: [id], onDelete: SetNull)

  @@index([createdAt])
  @@index([segment, createdAt])
}

model PlatformMessage {
  id            String    @id
  recipientType String
  recipientId   String?
  subject       String
  body          String
  channel       String    @default("DASHBOARD")
  status        String    @default("SENT")
  createdBy     String?
  createdAt     DateTime  @default(now())
  readAt        DateTime?

  @@index([recipientType, recipientId, createdAt])
  @@index([createdAt])
}

model RiderApplication {
  id                     String    @id
  userId                 String?   @unique
  fullName               String
  email                  String
  phone                  String
  idNumberLast4          String    @default("")
  idDocumentUrl          String?
  profilePhotoUrl        String?
  licenseCode            String    @default("")
  licenceDocumentUrl     String?
  licenceExpiry          DateTime?
  suburb                 String    @default("")
  city                   String    @default("")
  province               String    @default("")
  municipality           String    @default("")
  township               String    @default("")
  sectionArea            String?
  preferredZones         String    @default("[]")
  vehicleType            String    @default("")
  vehicleMakeModel       String?
  vehicleRegistration    String?
  vehicleDocumentUrl     String?
  availableNow           Boolean   @default(false)
  workingDays            String    @default("[]")
  startTime              String?
  endTime                String?
  availableHours         String    @default("")
  emergencyContactName   String    @default("")
  emergencyContactPhone  String    @default("")
  hasSmartphone          Boolean   @default(false)
  hasBankAccount         Boolean   @default(false)
  lawfulWorkDeclared     Boolean   @default(false)
  conductAccepted        Boolean   @default(false)
  liquorIdCheckAccepted  Boolean   @default(false)
  bankAccountName        String?
  bankName               String?
  bankAccountNumber      String?
  bankBranchCode         String?
  bankAccountType        String?
  bankVerificationStatus String    @default("UNVERIFIED")
  experience             String?
  aiSummary              String?
  status                 String    @default("DRAFT")
  reviewReason           String?
  submittedAt            DateTime?
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt

  user           User?   @relation(fields: [userId], references: [id], onDelete: Cascade)
  assignedOrders Order[]

  @@index([status, createdAt])
  @@index([email])
  @@index([phone])
}

model AppRateLimit {
  bucketId   String @id @map("bucket_id")
  scopeKey   String @map("scope_key")
  identifier String
  count      Int
  resetAt    BigInt @map("reset_at")
  updatedAt  BigInt @map("updated_at")

  @@index([resetAt], map: "app_rate_limits_reset_at_idx")
  @@map("app_rate_limits")
}

model AppOrderNotificationLog {
  id        String   @id
  orderId   String   @map("order_id")
  event     String
  channel   String
  createdAt DateTime @default(now()) @map("created_at")

  @@unique([orderId, event, channel], map: "app_order_notification_logs_unique")
  @@map("app_order_notification_logs")
}
